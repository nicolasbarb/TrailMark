default_platform(:ios)

# App Store Connect API Key (shared across projects)
API_KEY_PATH = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8")

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV['ASC_KEY_ID'],
    issuer_id: ENV['ASC_ISSUER_ID'],
    key_filepath: API_KEY_PATH,
    in_house: false
  )
end

PBXPROJ_PATH = File.expand_path("../trailmark.xcodeproj/project.pbxproj", __dir__)

# Update MARKETING_VERSION directly in pbxproj.
# agvtool is broken with GENERATE_INFOPLIST_FILE = YES (confuses "YES" for a plist path)
# and fails to update the build setting, leaving the IPA with the old version.
def set_marketing_version(version)
  text = File.read(PBXPROJ_PATH)
  count = text.gsub!(/MARKETING_VERSION = [^;]*;/, "MARKETING_VERSION = #{version};")
  UI.user_error!("No MARKETING_VERSION found in pbxproj") unless count
  File.write(PBXPROJ_PATH, text)
end

# Update CURRENT_PROJECT_VERSION directly in pbxproj (same agvtool issue).
def set_build_number(build)
  text = File.read(PBXPROJ_PATH)
  count = text.gsub!(/CURRENT_PROJECT_VERSION = [^;]*;/, "CURRENT_PROJECT_VERSION = #{build};")
  UI.user_error!("No CURRENT_PROJECT_VERSION found in pbxproj") unless count
  File.write(PBXPROJ_PATH, text)
end

# Read current MARKETING_VERSION from pbxproj.
def read_marketing_version
  text = File.read(PBXPROJ_PATH)
  match = text.match(/MARKETING_VERSION = ([^;]*);/)
  UI.user_error!("No MARKETING_VERSION found in pbxproj") unless match
  match[1].strip
end

platform :ios do
  before_all do
    unless File.exist?(API_KEY_PATH)
      UI.user_error!("AuthKey not found at #{API_KEY_PATH}. Download from App Store Connect > Users > Keys")
    end
    # Workaround for Xcode 26 altool bug (fastlane/fastlane#29739)
    ENV["DELIVER_ALTOOL_ADDITIONAL_UPLOAD_PARAMETERS"] = "--use-old-altool"
  end

  # ==================== MATCH ====================

  desc "Setup all certificates and profiles (development, adhoc, appstore)"
  lane :setup_match do
    UI.important("🔧 Génération des certificats Development...")
    match(type: "development", force: true, force_for_new_devices: true)

    UI.important("🔧 Génération des certificats AdHoc...")
    match(type: "adhoc", force: true, force_for_new_devices: true)

    UI.important("🔧 Génération des certificats App Store...")
    match(type: "appstore", force: true, force_for_new_devices: true)

    UI.success("✅ Tous les certificats et profils ont été créés avec succès!")
  end

  desc "Clean and regenerate all certificates and profiles"
  lane :regenerate_certificates do
    UI.important("🗑️  Suppression des certificats et profils...")
    match_nuke(type: "development", skip_confirmation: true)
    match_nuke(type: "adhoc", skip_confirmation: true)
    match_nuke(type: "appstore", skip_confirmation: true)

    UI.success("✅ Anciens certificats supprimés, régénération...")
    setup_match
  end

  # ==================== BETA ====================

  desc "Push a new build to TestFlight. Use bump:patch/minor/major to create a new App Store version."
  lane :beta do |options|
    is_new_version = !!options[:bump]

    # Validate bump parameter
    if is_new_version && !%w[patch minor major].include?(options[:bump])
      UI.user_error!("Invalid bump type '#{options[:bump]}'. Use patch, minor, or major.")
    end

    # Setup App Store Connect API Key
    api_key = asc_api_key

    # --- Version bump + App Store Connect version creation ---
    if is_new_version
      current_version = read_marketing_version

      version_parts = current_version.split('.')
      major = version_parts[0].to_i
      minor = version_parts[1]&.to_i || 0
      patch = version_parts[2]&.to_i || 0

      case options[:bump]
      when "major"
        major += 1
        minor = 0
        patch = 0
      when "minor"
        minor += 1
        patch = 0
      when "patch"
        patch += 1
      end

      new_version = "#{major}.#{minor}.#{patch}"

      set_marketing_version(new_version)
      UI.success("✅ Version incrémentée de #{current_version} à #{new_version}")

      # Create release branch from main
      sh("git checkout -b release/#{new_version}")
      UI.success("✅ Branche release/#{new_version} créée")

      # Create new version on App Store Connect with metadata
      deliver(
        api_key: api_key,
        app_version: new_version,
        skip_binary_upload: true,
        skip_screenshots: true,
        force: true,
        automatic_release: false,
        precheck_include_in_app_purchases: false
      )

      UI.success("✅ Version #{new_version} créée sur App Store Connect")

      # Reset build number to 1 for the new version
      set_build_number(1)
      lane_context[SharedValues::BUILD_NUMBER] = "1"
    else
      # No bump: increment build number based on latest TestFlight build
      latest_build = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier),
        initial_build_number: 0
      )

      new_build = latest_build + 1
      set_build_number(new_build)
      lane_context[SharedValues::BUILD_NUMBER] = new_build.to_s
    end

    # Setup certificates and provisioning profiles
    match(
      type: "appstore",
      api_key: api_key,
      readonly: is_ci,
      verbose: true
    )

    # Build the app
    build_app(
      scheme: "trailmark",
      project: "trailmark.xcodeproj",
      clean: true,
      output_directory: "./fastlane/builds",
      output_name: "trailmark",
      export_method: "app-store",
      xcargs: "-skipMacroValidation -skipPackagePluginValidation",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier) => "match AppStore #{CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)}"
        }
      }
    )

    # Get changelog from file (written by Claude before running the lane)
    changelog_path = File.expand_path("../changelog.txt", __dir__)
    if File.exist?(changelog_path)
      changelog = File.read(changelog_path).strip
      UI.success("✅ Changelog lu depuis fastlane/changelog.txt")
    else
      changelog = "Corrections de bugs et améliorations des performances"
      UI.important("⚠️  Aucun fichier changelog.txt trouvé, utilisation du changelog par défaut")
    end

    # Upload to TestFlight
    upload_to_testflight(
      ipa: "./fastlane/builds/trailmark.ipa",
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: changelog
    )

    # Commit version and build number changes
    version = read_marketing_version
    build = lane_context[SharedValues::BUILD_NUMBER]

    commit_version_bump(
      message: "Bump version to #{version} build #{build} [skip ci]",
      xcodeproj: "trailmark.xcodeproj",
      force: true
    )

    # Tag release only for new versions
    if is_new_version
      add_git_tag(tag: "v#{version}")
    end

    # Push to remote
    if is_new_version
      # Push release branch + tag
      push_to_git_remote(
        local_branch: "release/#{version}",
        tags: true
      )

      # Cherry-pick version bump into main
      bump_sha = sh("git rev-parse HEAD").strip
      sh("git checkout main")
      sh("git pull origin main")
      sh("git cherry-pick #{bump_sha}")
      push_to_git_remote(local_branch: "main")
      sh("git checkout release/#{version}")
    else
      push_to_git_remote(tags: false)
    end
  end

  # ==================== OTHER LANES ====================

  desc "Push metadata (description, keywords, etc.) to App Store Connect"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      project: "trailmark.xcodeproj",
      scheme: "trailmark",
      device: "iPhone 16"
    )
  end
end
