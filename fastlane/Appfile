app_identifier("com.nbarb.trailmark")
apple_id(ENV["APPLE_ID"] || "nicolas.barb.pro@gmail.com")
team_id("REDACTED_TEAM_ID")

# App Store Connect API Key
# Replace YOUR_KEY_ID and YOUR_ISSUER_ID after creating the key
api_key_path = File.join(Dir.pwd, "fastlane", "AuthKey.p8")
if File.exist?(api_key_path)
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"] || "REDACTED_KEY_ID",
    issuer_id: ENV["ASC_ISSUER_ID"] || "REDACTED_ISSUER_ID",
    key_filepath: api_key_path
  )
end

