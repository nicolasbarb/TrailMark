{
  "sourceLanguage" : "en",
  "strings" : {
    ".GPX" : {
      "comment" : "The file extension for GPX files. Used as a badge in the ImportView.",
      "isCommentAutoGenerated" : true
    },
    "·" : {
      "comment" : "A period used to separate different pieces of information in a list.",
      "isCommentAutoGenerated" : true
    },
    "#%lld" : {
      "comment" : "A label displaying the index of a milestone in a list. The argument is the index of the milestone.",
      "isCommentAutoGenerated" : true
    },
    "%" : {
      "comment" : "A unit of measurement for slope percentage.",
      "isCommentAutoGenerated" : true
    },
    "%@ · %@ %@" : {
      "comment" : "A label showing the milestone type and a relative distance (either \"ahead\" or \"behind\") followed by the distance value. The distance value is formatted.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@ %3$@"
          }
        }
      }
    },
    "%@%lld" : {
      "comment" : "Displays the slope percentage of a terrain segment. The text inside the parentheses is the actual percentage value.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@%2$lld"
          }
        }
      }
    },
    "%@%lld m" : {
      "comment" : "A label displaying the elevation change of a segment, with a plus or minus sign indicating whether it's an ascent or descent. The number following the sign is the elevation change in meters.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@%2$lld m"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A text view displaying the elevation of a specific track point, formatted as a whole number followed by a 'M' suffix",
      "isCommentAutoGenerated" : true
    },
    "%lld FPS" : {
      "comment" : "A label displaying the current frame rate of the view, in frames per second.",
      "isCommentAutoGenerated" : true
    },
    "%lld m" : {
      "comment" : "A label displaying the altitude of a given milestone. The argument is the altitude of the milestone.",
      "isCommentAutoGenerated" : true
    },
    "%lldk" : {
      "comment" : "A label displaying a distance in kilometers on the elevation profile view. The content of the label is dynamically generated based on the current distance being iterated.",
      "isCommentAutoGenerated" : true
    },
    "%lldm" : {
      "comment" : "A tooltip that appears when hovering over a point in the elevation profile view. It shows the altitude and distance at that point.",
      "isCommentAutoGenerated" : true
    },
    "🏔️" : {
      "comment" : "A placeholder icon representing a mountain.",
      "isCommentAutoGenerated" : true
    },
